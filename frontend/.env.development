# Development Environment Configuration
VITE_API_URL=http://localhost:5000/api/v1
VITE_API_VERSION=v1
VITE_API_TIMEOUT=30000
VITE_APP_ENV=development
VITE_ENABLE_DEVTOOLS=true
VITE_ENABLE_MOCK_DATA=false
VITE_LOG_LEVEL=debug
VITE_AUTH_BYPASS_MODE=false
VITE_AUTH_BYPASS_ROLE=superadmin
VITE_AUTH_BYPASS_ROLES=superadmin,institution_admin,school_admin,principal,teacher,student,parent,accountant,hr_manager,librarian,transport_manager,hostel_warden,staff_member
