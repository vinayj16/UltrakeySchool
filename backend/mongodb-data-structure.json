{
  "database": "eduserach",
  "description": "Educational Management System Database Structure",
  "collections": {
    "organizations": {
      "description": "Educational institutions and organizations",
      "schema": {
        "bsonType": "object",
        "required": ["name", "type", "code", "email", "status"],
        "properties": {
          "name": { "bsonType": "string" },
          "type": {
            "enum": ["SCHOOL", "INTER_COLLEGE", "DEGREE_COLLEGE", "ENGINEERING_COLLEGE", "UNIVERSITY"]
          },
          "code": { "bsonType": "string" },
          "email": { "bsonType": "string" },
          "phone": { "bsonType": "string" },
          "website": { "bsonType": "string" },
          "affiliation": { "bsonType": "string" },
          "accreditation": { "bsonType": "array", "items": { "bsonType": "string" } },
          "address": {
            "bsonType": "object",
            "properties": {
              "street": { "bsonType": "string" },
              "city": { "bsonType": "string" },
              "state": { "bsonType": "string" },
              "country": { "bsonType": "string" },
              "postalCode": { "bsonType": "string" }
            }
          },
          "logo": { "bsonType": "string" },
          "status": { "enum": ["ACTIVE", "INACTIVE", "SUSPENDED", "PENDING"] },
          "plan": { "enum": ["basic", "standard", "premium", "enterprise"] },
          "subscription": {
            "bsonType": "object",
            "properties": {
              "planId": { "bsonType": "string" },
              "startDate": { "bsonType": "date" },
              "endDate": { "bsonType": "date" },
              "billingCycle": { "enum": ["monthly", "yearly"] },
              "isActive": { "bsonType": "bool" },
              "autoRenew": { "bsonType": "bool" }
            }
          },
          "settings": {
            "bsonType": "object",
            "properties": {
              "academicYear": { "bsonType": "string" },
              "timezone": { "bsonType": "string" },
              "language": { "bsonType": "string" },
              "currency": { "bsonType": "string" },
              "dateFormat": { "bsonType": "string" },
              "timeFormat": { "enum": ["12h", "24h"] },
              "workingDays": { "bsonType": "array", "items": { "bsonType": "string" } },
              "workingHours": {
                "bsonType": "object",
                "properties": {
                  "start": { "bsonType": "string" },
                  "end": { "bsonType": "string" }
                }
              }
            }
          },
          "features": {
            "bsonType": "object",
            "properties": {
              "attendance": { "bsonType": "bool" },
              "examination": { "bsonType": "bool" },
              "fees": { "bsonType": "bool" },
              "library": { "bsonType": "bool" },
              "transport": { "bsonType": "bool" },
              "hostel": { "bsonType": "bool" },
              "canteen": { "bsonType": "bool" },
              "inventory": { "bsonType": "bool" },
              "communication": { "bsonType": "bool" },
              "reports": { "bsonType": "bool" }
            }
          },
          "contactPersons": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "name": { "bsonType": "string" },
                "designation": { "bsonType": "string" },
                "email": { "bsonType": "string" },
                "phone": { "bsonType": "string" },
                "isPrimary": { "bsonType": "bool" }
              }
            }
          },
          "branches": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "name": { "bsonType": "string" },
                "code": { "bsonType": "string" },
                "address": {
                  "bsonType": "object",
                  "properties": {
                    "street": { "bsonType": "string" },
                    "city": { "bsonType": "string" },
                    "state": { "bsonType": "string" },
                    "country": { "bsonType": "string" },
                    "postalCode": { "bsonType": "string" }
                  }
                },
                "phone": { "bsonType": "string" },
                "email": { "bsonType": "string" },
                "status": { "enum": ["ACTIVE", "INACTIVE"] }
              }
            }
          },
          "statistics": {
            "bsonType": "object",
            "properties": {
              "totalStudents": { "bsonType": "number" },
              "totalTeachers": { "bsonType": "number" },
              "totalStaff": { "bsonType": "number" },
              "totalClasses": { "bsonType": "number" },
              "lastUpdated": { "bsonType": "date" }
            }
          },
          "createdAt": { "bsonType": "date" },
          "updatedAt": { "bsonType": "date" }
        }
      },
      "indexes": [
        { "key": { "type": 1, "status": 1 } },
        { "key": { "code": 1 }, "unique": true },
        { "key": { "email": 1 }, "unique": true },
        { "key": { "address.city": 1 } },
        { "key": { "plan": 1 } },
        { "key": { "createdAt": -1 } }
      ]
    },
    "users": {
      "description": "All system users with roles and permissions",
      "schema": {
        "bsonType": "object",
        "required": ["name", "email", "password", "role"],
        "properties": {
          "name": { "bsonType": "string" },
          "email": { "bsonType": "string" },
          "password": { "bsonType": "string" },
          "role": {
            "enum": ["superadmin", "organization_admin", "school_admin", "principal", "teacher", "student", "parent", "accountant", "hr_manager", "librarian", "transport_manager", "hostel_warden", "staff_member"]
          },
          "organizationId": { "bsonType": "objectId" },
          "schoolId": { "bsonType": "string" },
          "avatar": { "bsonType": "string" },
          "phone": { "bsonType": "string" },
          "address": {
            "bsonType": "object",
            "properties": {
              "street": { "bsonType": "string" },
              "city": { "bsonType": "string" },
              "state": { "bsonType": "string" },
              "zipCode": { "bsonType": "string" },
              "country": { "bsonType": "string" }
            }
          },
          "dateOfBirth": { "bsonType": "date" },
          "gender": { "enum": ["male", "female", "other"] },
          "status": { "enum": ["active", "inactive", "suspended"] },
          "lastLogin": { "bsonType": "date" },
          "refreshToken": { "bsonType": "string" },
          "permissions": { "bsonType": "array", "items": { "bsonType": "string" } },
          "modules": { "bsonType": "array", "items": { "bsonType": "string" } },
          "preferences": {
            "bsonType": "object",
            "properties": {
              "theme": { "enum": ["light", "dark", "auto"] },
              "colorScheme": { "enum": ["blue", "green", "purple", "orange", "red"] },
              "fontSize": { "enum": ["small", "medium", "large", "xlarge"] },
              "language": { "bsonType": "string" },
              "notifications": {
                "bsonType": "object",
                "properties": {
                  "email": { "bsonType": "bool" },
                  "sms": { "bsonType": "bool" },
                  "push": { "bsonType": "bool" }
                }
              },
              "accessibility": {
                "bsonType": "object",
                "properties": {
                  "highContrast": { "bsonType": "bool" },
                  "reducedMotion": { "bsonType": "bool" },
                  "screenReader": { "bsonType": "bool" }
                }
              }
            }
          },
          "deviceTokens": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "token": { "bsonType": "string" },
                "platform": { "enum": ["ios", "android", "web"] },
                "addedAt": { "bsonType": "date" }
              }
            }
          },
          "biometricData": {
            "bsonType": "object",
            "properties": {
              "fingerprintHash": { "bsonType": "string" },
              "deviceId": { "bsonType": "string" },
              "registeredAt": { "bsonType": "date" },
              "isActive": { "bsonType": "bool" }
            }
          },
          "faceRecognitionData": {
            "bsonType": "object",
            "properties": {
              "encoding": { "bsonType": "array", "items": { "bsonType": "number" } },
              "imageUrl": { "bsonType": "string" },
              "registeredAt": { "bsonType": "date" },
              "isActive": { "bsonType": "bool" }
            }
          },
          "personalQRCode": {
            "bsonType": "object",
            "properties": {
              "data": { "bsonType": "string" },
              "imageUrl": { "bsonType": "string" },
              "generatedAt": { "bsonType": "date" }
            }
          },
          "teacherDetails": {
            "bsonType": "object",
            "properties": {
              "subject": { "bsonType": "string" },
              "employeeId": { "bsonType": "string" },
              "qualifications": { "bsonType": "array", "items": { "bsonType": "string" } },
              "experience": { "bsonType": "number" },
              "department": { "bsonType": "string" },
              "specialization": { "bsonType": "string" },
              "classesAssigned": { "bsonType": "array", "items": { "bsonType": "string" } }
            }
          },
          "studentDetails": {
            "bsonType": "object",
            "properties": {
              "rollNumber": { "bsonType": "string" },
              "class": { "bsonType": "string" },
              "section": { "bsonType": "string" },
              "admissionDate": { "bsonType": "date" },
              "guardianId": { "bsonType": "objectId" },
              "branch": { "bsonType": "string" },
              "semester": { "bsonType": "number" },
              "enrollmentNumber": { "bsonType": "string" },
              "realtime": {
                "bsonType": "object",
                "properties": {
                  "gpa": { "bsonType": "number" },
                  "attendancePercent": { "bsonType": "number" },
                  "lastUpdated": { "bsonType": "date" }
                }
              }
            }
          },
          "parentDetails": {
            "bsonType": "object",
            "properties": {
              "occupation": { "bsonType": "string" },
              "phone": { "bsonType": "string" },
              "address": { "bsonType": "string" },
              "relationship": { "enum": ["father", "mother", "guardian"] }
            }
          },
          "staffDetails": {
            "bsonType": "object",
            "properties": {
              "employeeId": { "bsonType": "string" },
              "department": { "bsonType": "string" },
              "designation": { "bsonType": "string" },
              "joiningDate": { "bsonType": "date" },
              "salary": { "bsonType": "number" },
              "qualifications": { "bsonType": "array", "items": { "bsonType": "string" } }
            }
          },
          "isActive": { "bsonType": "bool" },
          "emailVerified": { "bsonType": "bool" },
          "twoFactorEnabled": { "bsonType": "bool" },
          "createdAt": { "bsonType": "date" },
          "updatedAt": { "bsonType": "date" }
        }
      },
      "indexes": [
        { "key": { "organizationId": 1, "role": 1 } },
        { "key": { "email": 1 }, "unique": true },
        { "key": { "schoolId": 1 } },
        { "key": { "status": 1 } },
        { "key": { "lastLogin": -1 } },
        { "key": { "createdAt": -1 } }
      ]
    },
    "classes": {
      "description": "Academic classes and grade sections",
      "schema": {
        "bsonType": "object",
        "required": ["organizationId", "name", "grade", "section", "academicYear"],
        "properties": {
          "organizationId": { "bsonType": "objectId" },
          "name": { "bsonType": "string" },
          "grade": { "bsonType": "string" },
          "section": { "bsonType": "string" },
          "academicYear": { "bsonType": "string" },
          "classTeacher": { "bsonType": "objectId" },
          "subjects": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "name": { "bsonType": "string" },
                "code": { "bsonType": "string" },
                "teacher": { "bsonType": "objectId" },
                "isOptional": { "bsonType": "bool" },
                "credits": { "bsonType": "number" }
              }
            }
          },
          "students": { "bsonType": "array", "items": { "bsonType": "objectId" } },
          "capacity": { "bsonType": "number" },
          "status": { "enum": ["ACTIVE", "INACTIVE", "COMPLETED"] },
          "timetable": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "day": { "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"] },
                "periods": {
                  "bsonType": "array",
                  "items": {
                    "bsonType": "object",
                    "properties": {
                      "subject": { "bsonType": "string" },
                      "teacher": { "bsonType": "objectId" },
                      "startTime": { "bsonType": "string" },
                      "endTime": { "bsonType": "string" },
                      "room": { "bsonType": "string" }
                    }
                  }
                }
              }
            }
          },
          "createdAt": { "bsonType": "date" },
          "updatedAt": { "bsonType": "date" }
        }
      },
      "indexes": [
        { "key": { "organizationId": 1, "grade": 1, "section": 1 } },
        { "key": { "classTeacher": 1 } },
        { "key": { "academicYear": 1 } },
        { "key": { "status": 1 } }
      ]
    },
    "subjects": {
      "description": "Academic subjects and curriculum",
      "schema": {
        "bsonType": "object",
        "required": ["organizationId", "name", "code"],
        "properties": {
          "organizationId": { "bsonType": "objectId" },
          "name": { "bsonType": "string" },
          "code": { "bsonType": "string" },
          "description": { "bsonType": "string" },
          "category": { "enum": ["CORE", "ELECTIVE", "PRACTICAL", "LANGUAGE"] },
          "grade": { "bsonType": "string" },
          "syllabus": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "chapter": { "bsonType": "string" },
                "topics": { "bsonType": "array", "items": { "bsonType": "string" } },
                "duration": { "bsonType": "number" },
                "order": { "bsonType": "number" }
              }
            }
          },
          "textbooks": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "title": { "bsonType": "string" },
                "author": { "bsonType": "string" },
                "publisher": { "bsonType": "string" },
                "isbn": { "bsonType": "string" },
                "required": { "bsonType": "bool" }
              }
            }
          },
          "assessment": {
            "bsonType": "object",
            "properties": {
              "continuous": { "bsonType": "number" },
              "final": { "bsonType": "number" },
              "practical": { "bsonType": "number" }
            }
          },
          "status": { "enum": ["ACTIVE", "INACTIVE"] },
          "createdAt": { "bsonType": "date" },
          "updatedAt": { "bsonType": "date" }
        }
      },
      "indexes": [
        { "key": { "organizationId": 1, "code": 1 }, "unique": true },
        { "key": { "category": 1 } },
        { "key": { "grade": 1 } },
        { "key": { "status": 1 } }
      ]
    },
    "attendance": {
      "description": "Daily attendance records for students, teachers, and staff",
      "schema": {
        "bsonType": "object",
        "required": ["organizationId", "userId", "userType", "date", "status"],
        "properties": {
          "organizationId": { "bsonType": "objectId" },
          "userId": { "bsonType": "objectId" },
          "userType": { "enum": ["student", "teacher", "staff"] },
          "classId": { "bsonType": "objectId" },
          "date": { "bsonType": "date" },
          "status": { "enum": ["present", "absent", "late", "excused"] },
          "checkInTime": { "bsonType": "date" },
          "checkOutTime": { "bsonType": "date" },
          "duration": { "bsonType": "number" },
          "markedBy": { "bsonType": "objectId" },
          "notes": { "bsonType": "string" },
          "location": {
            "bsonType": "object",
            "properties": {
              "latitude": { "bsonType": "number" },
              "longitude": { "bsonType": "number" },
              "accuracy": { "bsonType": "number" }
            }
          },
          "deviceInfo": {
            "bsonType": "object",
            "properties": {
              "ip": { "bsonType": "string" },
              "userAgent": { "bsonType": "string" },
              "deviceId": { "bsonType": "string" }
            }
          },
          "createdAt": { "bsonType": "date" },
          "updatedAt": { "bsonType": "date" }
        }
      },
      "indexes": [
        { "key": { "organizationId": 1, "date": -1 } },
        { "key": { "userId": 1, "date": -1 } },
        { "key": { "classId": 1, "date": -1 } },
        { "key": { "status": 1 } },
        { "key": { "markedBy": 1 } }
      ]
    },
    "exams": {
      "description": "Examination schedules and configurations",
      "schema": {
        "bsonType": "object",
        "required": ["organizationId", "name", "type", "academicYear", "term"],
        "properties": {
          "organizationId": { "bsonType": "objectId" },
          "name": { "bsonType": "string" },
          "type": { "enum": ["UNIT_TEST", "MID_TERM", "FINAL", "PRACTICAL", "PROJECT", "QUIZ"] },
          "academicYear": { "bsonType": "string" },
          "term": { "bsonType": "string" },
          "subjects": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "subjectId": { "bsonType": "objectId" },
                "classId": { "bsonType": "objectId" },
                "date": { "bsonType": "date" },
                "startTime": { "bsonType": "string" },
                "endTime": { "bsonType": "string" },
                "room": { "bsonType": "string" },
                "invigilator": { "bsonType": "objectId" },
                "maxMarks": { "bsonType": "number" },
                "passingMarks": { "bsonType": "number" },
                "syllabus": { "bsonType": "string" }
              }
            }
          },
          "status": { "enum": ["DRAFT", "PUBLISHED", "ONGOING", "COMPLETED", "CANCELLED"] },
          "instructions": { "bsonType": "array", "items": { "bsonType": "string" } },
          "createdBy": { "bsonType": "objectId" },
          "createdAt": { "bsonType": "date" },
          "updatedAt": { "bsonType": "date" }
        }
      },
      "indexes": [
        { "key": { "organizationId": 1, "academicYear": 1 } },
        { "key": { "type": 1, "status": 1 } },
        { "key": { "createdBy": 1 } },
        { "key": { "status": 1 } }
      ]
    },
    "results": {
      "description": "Examination results and grades",
      "schema": {
        "bsonType": "object",
        "required": ["organizationId", "examId", "studentId", "subjectId", "classId", "marks"],
        "properties": {
          "organizationId": { "bsonType": "objectId" },
          "examId": { "bsonType": "objectId" },
          "studentId": { "bsonType": "objectId" },
          "subjectId": { "bsonType": "objectId" },
          "classId": { "bsonType": "objectId" },
          "marks": {
            "bsonType": "object",
            "required": ["obtained", "total"],
            "properties": {
              "obtained": { "bsonType": "number" },
              "total": { "bsonType": "number" },
              "percentage": { "bsonType": "number" },
              "grade": { "bsonType": "string" },
              "gradePoint": { "bsonType": "number" }
            }
          },
          "assessment": {
            "bsonType": "object",
            "properties": {
              "theory": { "bsonType": "number" },
              "practical": { "bsonType": "number" },
              "continuous": { "bsonType": "number" },
              "project": { "bsonType": "number" }
            }
          },
          "status": { "enum": ["PRESENT", "ABSENT", "WITHHELD", "CANCELLED"] },
          "remarks": { "bsonType": "string" },
          "enteredBy": { "bsonType": "objectId" },
          "enteredAt": { "bsonType": "date" },
          "createdAt": { "bsonType": "date" },
          "updatedAt": { "bsonType": "date" }
        }
      },
      "indexes": [
        { "key": { "examId": 1, "studentId": 1 }, "unique": true },
        { "key": { "organizationId": 1, "subjectId": 1 } },
        { "key": { "studentId": 1, "examId": 1 } },
        { "key": { "classId": 1 } },
        { "key": { "enteredBy": 1 } }
      ]
    },
    "fee_structures": {
      "description": "Fee structures for different classes and services",
      "schema": {
        "bsonType": "object",
        "required": ["organizationId", "name", "type", "academicYear"],
        "properties": {
          "organizationId": { "bsonType": "objectId" },
          "name": { "bsonType": "string" },
          "type": { "enum": ["TUITION", "TRANSPORT", "HOSTEL", "EXAMINATION", "LIBRARY", "SPORTS", "OTHER"] },
          "academicYear": { "bsonType": "string" },
          "applicableTo": {
            "bsonType": "object",
            "properties": {
              "classes": { "bsonType": "array", "items": { "bsonType": "objectId" } },
              "grades": { "bsonType": "array", "items": { "bsonType": "string" } },
              "allClasses": { "bsonType": "bool" }
            }
          },
          "feeBreakdown": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "component": { "bsonType": "string" },
                "amount": { "bsonType": "number" },
                "frequency": { "enum": ["ONE_TIME", "MONTHLY", "QUARTERLY", "HALF_YEARLY", "YEARLY"] },
                "isMandatory": { "bsonType": "bool" },
                "description": { "bsonType": "string" }
              }
            }
          },
          "totalAmount": { "bsonType": "number" },
          "discounts": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "name": { "bsonType": "string" },
                "type": { "enum": ["PERCENTAGE", "FIXED"] },
                "value": { "bsonType": "number" },
                "conditions": { "bsonType": "string" },
                "applicableTo": { "bsonType": "array", "items": { "bsonType": "string" } }
              }
            }
          },
          "paymentSchedule": {
            "bsonType": "array",
            "items": {
              "bsonType": "object",
              "properties": {
                "installment": { "bsonType": "number" },
                "dueDate": { "bsonType": "date" },
                "amount": { "bsonType": "number" },
                "description": { "bsonType": "string" }
              }
            }
          },
          "status": { "enum": ["ACTIVE", "INACTIVE"] },
          "createdAt": { "bsonType": "date" },
          "updatedAt": { "bsonType": "date" }
        }
      },
      "indexes": [
        { "key": { "organizationId": 1, "type": 1 } },
        { "key": { "academicYear": 1 } },
        { "key": { "status": 1 } }
      ]
    },
    "payments": {
      "description": "Fee payment records and transactions",
      "schema": {
        "bsonType": "object",
        "required": ["organizationId", "studentId", "amount", "paymentMethod", "paymentDate"],
        "properties": {
          "organizationId": { "bsonType": "objectId" },
          "studentId": { "bsonType": "objectId" },
          "feeStructureId": { "bsonType": "objectId" },
          "amount": { "bsonType": "number" },
          "paymentMethod": { "enum": ["CASH", "CHEQUE", "ONLINE", "CARD", "UPI", "BANK_TRANSFER"] },
