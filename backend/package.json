{
  "name": "edumanage-backend",
  "version": "1.0.0",
  "description": "Backend API for EduManage Pro - Complete School Management System",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node kill-port.js 5000 && nodemon src/server.js",
    "dev:force": "node kill-port.js 5000 && node src/server.js",
    "kill-port": "node kill-port.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:connection": "node test-connection.js",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.js\"",
    "seed": "node src/scripts/seedData.js",
    "seed:performers": "node src/scripts/seedPerformers.js",
    "seed:fees": "node src/scripts/seedFees.js",
    "seed:schedules": "node src/scripts/seedSchedules.js",
    "seed:statistics": "node src/scripts/seedStatistics.js",
    "seed:sidebar": "node src/scripts/seedSidebar.js",
    "seed:superadmin": "node src/scripts/seedSuperAdmin.js",
    "seed:teachers": "node src/scripts/seedTeachers.js",
    "seed:subscriptions": "node src/scripts/seedSubscriptions.js",
    "seed:users": "node src/scripts/seedUsers.js",
    "seed:menus": "node src/scripts/seedMenus.js",
    "seed:institutions": "node src/scripts/seedInstitutions.js",
    "seed:hrm": "node src/scripts/seedHRM.js",
    "seed:settings": "node src/scripts/seedSettings.js",
    "seed:supporttickets": "node src/scripts/seedSupportTickets.js",
    "seed:classes": "node src/scripts/seedClasses.js",
    "seed:classrooms": "node src/scripts/seedClassRooms.js",
    "seed:religions": "node src/scripts/seedReligions.js",
    "seed:schoolsettings": "node src/scripts/seedSchoolSettings.js",
    "seed:grades": "node src/scripts/seedGrades.js",
    "seed:examschedules": "node src/scripts/seedExamSchedules.js",
    "seed:notices": "node src/scripts/seedNotices.js",
    "seed:todos": "node src/scripts/seedTodos.js",
    "seed:notes": "node src/scripts/seedNotes.js",
    "seed:filemanager": "node src/scripts/seedFileManager.js",
    "seed:emails": "node src/scripts/seedEmails.js",
    "seed:studentattendance": "node src/scripts/seedStudentAttendance.js",
    "seed:auth": "node src/scripts/seedAuth.js",
    "seed:initial": "node src/scripts/seedInitialUser.js",
    "seed:mock-schools": "node src/scripts/seedMockSchools.js",
    "seed:structure": "node src/scripts/seedMongoStructure.js",
    "seed:all": "npm run seed && npm run seed:performers && npm run seed:fees && npm run seed:schedules && npm run seed:statistics && npm run seed:sidebar && npm run seed:superadmin && npm run seed:teachers && npm run seed:subscriptions && npm run seed:users && npm run seed:menus && npm run seed:institutions && npm run seed:hrm && npm run seed:settings && npm run seed:supporttickets && npm run seed:classes && npm run seed:classrooms && npm run seed:religions && npm run seed:schoolsettings && npm run seed:grades && npm run seed:examschedules && npm run seed:notices && npm run seed:todos && npm run seed:notes && npm run seed:filemanager && npm run seed:emails && npm run seed:studentattendance && npm run seed:auth"
  },
  "keywords": [
    "education",
    "school-management",
    "attendance",
    "api",
    "express",
    "mongodb",
    "nodejs"
  ],
  "author": "EduManage Team",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.40.0",
    "@sentry/profiling-node": "^10.40.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "bullmq": "^5.70.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.6.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.6.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "otplib": "^13.3.0",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "redis": "^4.6.12",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.12.2",
    "uuid": "^10.0.0",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.0.1",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
